@page "/gatt-monitor/{AddressRaw}"
@rendermode InteractiveServer
@using BluetoothTracker.Services
@using System.Globalization
@using Windows.Devices.Bluetooth
@inject GattTrackerService Tracker
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>GATT Tracking @targetMac</PageTitle>

<div class="mb-3 d-flex align-items-center gap-3 flex-wrap">
    <a href="/watch" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i>Back</a>
    <span class="font-monospace text-muted">@targetMac</span>
    <span class="badge bg-secondary">Random address</span>
</div>

<div class="row g-4 mb-4">
    <!-- Status card -->
    <div class="col-12">
        <div class="card border-@StatusColor()">
            <div class="card-body d-flex align-items-center gap-4 flex-wrap">
                <div>@((MarkupString)StatusIcon())</div>
                <div class="flex-grow-1">
                    <h2 class="mb-1">@StatusLabel()</h2>
                    <div class="text-muted small">
                        @if (Tracker.Status == TrackingStatus.Connecting)
                        {
                            <span>Attempting GATT connection&hellip;</span>
                        }
                        else if (Tracker.Status == TrackingStatus.InRange && Tracker.LastSeen.HasValue)
                        {
                            <span>Last confirmed in range: @Tracker.LastSeen.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                        }
                        else if (Tracker.Status == TrackingStatus.OutOfRange)
                        {
                            <span>
                                @if (Tracker.LastSeen.HasValue)
                                {
                                    var age = DateTime.UtcNow - Tracker.LastSeen.Value;
                                    <text>Last seen @FormatAge(age) ago &mdash; </text>
                                }
                                @if (Tracker.LastError is not null)
                                {
                                    <text>@Tracker.LastError</text>
                                }
                            </span>
                        }
                    </div>
                </div>
                <div class="text-end d-flex flex-column align-items-end gap-2">
                    @if (Tracker.BatteryLevel.HasValue)
                    {
                        <div>
                            <div class="text-muted small">Battery</div>
                            <span class="fw-bold fs-5">@Tracker.BatteryLevel %</span>
                        </div>
                    }
                    <div class="d-flex gap-2">
                        @if (!Tracker.IsTracking)
                        {
                            <button class="btn btn-success" @onclick="Start">Start Tracking</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger" @onclick="Stop">Stop</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Poll interval -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="text-muted mb-2">Poll Interval</h6>
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var (label, secs) in new[] { ("5s", 5), ("15s", 15), ("30s", 30), ("60s", 60) })
                    {
                        <button class="btn btn-sm @(pollSeconds == secs ? "btn-primary" : "btn-outline-secondary")"
                                @onclick="() => SetInterval(secs)">@label</button>
                    }
                </div>
                <div class="text-muted small mt-2">
                    Next poll in @nextPollSecs s
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">In Range</div>
                <div class="fs-4 fw-bold text-success">@inRangeCount</div>
                <div class="text-muted small">of @totalPolls polls</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="text-muted small mb-1">Last Seen</div>
                <div class="fw-semibold">
                    @if (Tracker.LastSeen.HasValue)
                    {
                        @FormatAge(DateTime.UtcNow - Tracker.LastSeen.Value)<text> ago</text>
                    }
                    else
                    {
                        <text>Never</text>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- History timeline -->
@if (history.Any())
{
    <h5 class="text-muted mb-2">Poll History (newest first)</h5>
    <div class="d-flex flex-wrap gap-1 mb-2">
        @foreach (var e in history.AsEnumerable().Reverse())
        {
            <div class="poll-block bg-@(e.InRange ? "success" : "danger")"
                 title="@e.Time.ToLocalTime().ToString("HH:mm:ss") — @(e.InRange ? "In Range" : "Out of Range")">
            </div>
        }
    </div>
    <div class="d-flex gap-4 text-muted small mb-4">
        <span><span class="poll-block bg-success d-inline-block"></span> In Range</span>
        <span><span class="poll-block bg-danger d-inline-block"></span> Out of Range</span>
    </div>
}

<div class="alert alert-info" style="max-width:540px">
    <strong>Note:</strong> The PebbleBee must be in connectable mode (press button 5&times;) for each poll.
    If it times out between presses, the status will show Out of Range until re-activated.
    This is normal — we're using GATT connection as the proximity signal since passive BLE scanning
    can't see this device's advertisements on this adapter.
</div>

@code {
    [Parameter] public string AddressRaw { get; set; } = string.Empty;

    private ulong address;
    private string targetMac = string.Empty;
    private System.Threading.Timer? _uiTimer;

    private int pollSeconds = 15;
    private int nextPollSecs;
    private int inRangeCount;
    private int totalPolls;
    private IReadOnlyList<TrackingEvent> history = Array.Empty<TrackingEvent>();

    protected override void OnInitialized()
    {
        address = ulong.TryParse(AddressRaw, out var parsed) ? parsed : 0;
        targetMac = FormatMac(address);

        Tracker.StatusChanged += OnStatusChanged;
        _uiTimer = new System.Threading.Timer(_ => InvokeAsync(Tick), null,
            TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !Tracker.IsTracking)
            Start();
    }

    private void Start()
    {
        Tracker.PollInterval = TimeSpan.FromSeconds(pollSeconds);
        Tracker.StartTracking(address, Windows.Devices.Bluetooth.BluetoothAddressType.Random);
        StateHasChanged();
    }

    private void Stop()
    {
        Tracker.StopTracking();
        StateHasChanged();
    }

    private void SetInterval(int secs)
    {
        pollSeconds = secs;
        Tracker.PollInterval = TimeSpan.FromSeconds(secs);
    }

    private void OnStatusChanged() => InvokeAsync(Refresh);

    private void Tick()
    {
        // Countdown to next poll
        if (Tracker.IsTracking && Tracker.Status != TrackingStatus.Connecting)
        {
            nextPollSecs = Math.Max(0, nextPollSecs - 1);
            if (nextPollSecs == 0) nextPollSecs = pollSeconds;
        }
        StateHasChanged();
    }

    private void Refresh()
    {
        history = Tracker.History;
        totalPolls = history.Count;
        inRangeCount = history.Count(e => e.InRange);
        nextPollSecs = pollSeconds;
        StateHasChanged();
    }

    private string StatusColor() => Tracker.Status switch
    {
        TrackingStatus.InRange    => "success",
        TrackingStatus.OutOfRange => "danger",
        TrackingStatus.Connecting => "warning",
        _                         => "secondary"
    };

    private string StatusLabel() => Tracker.Status switch
    {
        TrackingStatus.InRange    => "In Range",
        TrackingStatus.OutOfRange => "Out of Range",
        TrackingStatus.Connecting => "Connecting...",
        _                         => "Idle"
    };

    private string StatusIcon() => Tracker.Status switch
    {
        TrackingStatus.InRange    => "<i class='fa-solid fa-circle-check fa-2x text-success'></i>",
        TrackingStatus.OutOfRange => "<i class='fa-solid fa-circle-xmark fa-2x text-danger'></i>",
        TrackingStatus.Connecting => "<i class='fa-solid fa-rotate fa-spin fa-2x text-warning'></i>",
        _                         => "<i class='fa-solid fa-pause fa-2x text-secondary'></i>"
    };

    private static string FormatAge(TimeSpan age)
    {
        if (age.TotalSeconds < 60) return $"{(int)age.TotalSeconds}s";
        if (age.TotalMinutes < 60) return $"{(int)age.TotalMinutes}m";
        return $"{(int)age.TotalHours}h {age.Minutes}m";
    }

    private static string FormatMac(ulong addr) =>
        string.Join(":", BitConverter.GetBytes(addr).Take(6).Reverse().Select(b => b.ToString("X2")));

    public void Dispose()
    {
        _uiTimer?.Dispose();
        Tracker.StatusChanged -= OnStatusChanged;
    }
}
